{
  "name": "ng-nordpool",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-env.js --local",
    "start": "ng serve",
    "predev": "node scripts/generate-env.js --local",
    "dev": "ng serve --port 3000",
    "pretest": "node scripts/generate-env.js --local",
    "prebuild": "node scripts/generate-env.js && node -e \"const fs=require('fs');fs.writeFileSync('src/environments/build-info.ts','export const BUILD_DATE = \\\"'+new Date().toISOString()+'\\\";\\n');\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "vitest": "^4.1.6"
  }
}
